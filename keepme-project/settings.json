{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",

      "Bash(git *)",
      "Bash(npm run *)",
      "Bash(docker-compose *)",
      "Bash(docker compose *)",
      "Bash(python3 *)",
      "Bash(pip install *)",
      "Bash(wc *)",
      "Bash(cp *)",
      "Bash(mkdir *)",
      "Bash(rsync *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(cat *)",

      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl exec *)",
      "Bash(kubectl apply *)",
      "Bash(kubectl annotate *)",
      "Bash(kubectl rollout *)",
      "Bash(kubectl scale *)",
      "Bash(kubectl run *)",
      "Bash(kubectl delete pod *)",
      "Bash(kubectl patch *)",
      "Bash(kubectl port-forward *)",

      "Bash(aws glue *)",
      "Bash(aws s3 *)",
      "Bash(aws s3api *)",
      "Bash(aws redshift *)",
      "Bash(aws redshift-data *)",
      "Bash(aws redshift-serverless *)",
      "Bash(aws sts *)",
      "Bash(aws eks *)",
      "Bash(aws logs *)",
      "Bash(aws cloudwatch *)",

      "Bash(curl -s http://10.200.95.52:8081*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(kubectl delete namespace *)",
      "Bash(kubectl delete deployment *)",
      "Bash(aws s3 rb *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(secret/*)",
      "Read(keepme_minhlt)",
      "Read(keepme_server.pem)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SKILLS_DIR=\"$(dirname \"$CLAUDE_CONFIG_DIR\")/skills/claude-scientific-skills\"; if [ -d \"$SKILLS_DIR/.git\" ]; then git -C \"$SKILLS_DIR\" pull --quiet 2>/dev/null; else git clone https://github.com/K-Dense-AI/claude-scientific-skills.git \"$SKILLS_DIR\" --quiet 2>/dev/null; fi"
          }
        ]
      }
    ]
  }
}
