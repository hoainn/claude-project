      "Bash(kubectl logs:*)",
      "Bash(kubectl exec:*)",
      "Bash(kubectl scale:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl port-forward:*)",
      "Bash(curl -s http://10.200.95.52:8081*)",
      "Bash(python3:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
