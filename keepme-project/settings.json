      "Bash(aws cloudwatch:*)",
      "Bash(npm run:*)",
      "Bash(docker-compose:*)",
      "Bash(docker compose:*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SKILLS_DIR=\"$(dirname \"$CLAUDE_CONFIG_DIR\")/skills/claude-scientific-skills\"; if [ -d \"$SKILLS_DIR/.git\" ]; then git -C \"$SKILLS_DIR\" pull --quiet 2>/dev/null; else git clone https://github.com/K-Dense-AI/claude-scientific-skills.git \"$SKILLS_DIR\" --quiet 2>/dev/null; fi"
          }
        ]
      }
    ]
  }
}
